@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthTokenStore TokenStore

@if (!isRegistering)
{
    <h3>Login</h3>
    
    <div style="max-width: 400px;">
        <div class="mb-2">
            <input @bind="username" placeholder="Username" class="form-control" />
        </div>
        <div class="mb-2">
            <input @bind="password" type="password" placeholder="Password" class="form-control" />
        </div>
        <button class="btn btn-primary" @onclick="LoginUser" disabled="@isLoading">
            @(isLoading ? "Logging in..." : "Login")
        </button>

        <p class="mt-3">
            Don't have an account?
            <a href="#" @onclick="ToggleForm" @onclick:preventDefault>Register here</a>
        </p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="text-danger">@message</p>
        }
    </div>
}
else
{
    <h3>Create Account</h3>

    <div style="max-width: 400px;">
        <div class="mb-2">
            <input @bind="username" placeholder="Username" class="form-control" />
        </div>
        <div class="mb-2">
            <input @bind="email" placeholder="Email" type="email" class="form-control" />
        </div>
        <div class="mb-2">
            <input @bind="password" type="password" placeholder="Password" class="form-control" />
        </div>
        <div class="mb-2">
            <input @bind="confirmPassword" type="password" placeholder="Confirm Password" class="form-control" />
        </div>
        <button class="btn btn-primary" @onclick="RegisterUser" disabled="@isLoading">
            @(isLoading ? "Creating..." : "Create Account")
        </button>

        <p class="mt-3">
            Already have an account?
            <a href="#" @onclick="ToggleForm" @onclick:preventDefault>Login here</a>
        </p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <p class="@messageClass">@message</p>
        }
    </div>
}

@code {
    private string username = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string message = string.Empty;
    private string messageClass = "text-danger";
    private bool isLoading;
    private bool isRegistering;

    private void ToggleForm()
    {
        isRegistering = !isRegistering;
        username = string.Empty;
        email = string.Empty;
        password = string.Empty;
        confirmPassword = string.Empty;
        message = string.Empty;
    }

    private async Task LoginUser()
    {
        isLoading = true;
        message = string.Empty;

        var response = await Http.PostAsJsonAsync("api/auth/login", new
        {
            Username = username,
            Password = password
        });

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if (result is null || string.IsNullOrWhiteSpace(result.Token))
            {
                message = "Login failed: no token returned.";
                isLoading = false;
                return;
            }

            await TokenStore.SetTokenAsync(result.Token);
            Nav.NavigateTo("/dashboard", forceLoad: false);
        }
        else
        {
            message = "Invalid username or password.";
        }

        isLoading = false;
    }

    private async Task RegisterUser()
    {
        message = string.Empty;

        if (password != confirmPassword)
        {
            message = "Passwords do not match.";
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", new
            {
                username,
                email,
                password
            });

            if (response.IsSuccessStatusCode)
            {
                isRegistering = false;
                username = string.Empty;
                email = string.Empty;
                password = string.Empty;
                confirmPassword = string.Empty;
                message = "Account created! You can now log in.";
                messageClass = "text-success";
                }
            else
            {
                messageClass = "text-danger";
    if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
    {
        message = await response.Content.ReadAsStringAsync();
    }
    else
    {
        message = "Please check your input and try again.";
    }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
        public DateTime ExpiresAtUtc { get; set; }
    }
}
