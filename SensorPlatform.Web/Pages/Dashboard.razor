@page "/dashboard"
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthTokenStore TokenStore

<h3>Sensor Dashboard</h3>

<button class="btn btn-primary mb-3" @onclick="LoadData">
    Refresh
</button>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}

@if (isLoading)
{
    <p>Loading...</p>
}
else if (latestReadings == null || !latestReadings.Any())
{
    <p>No data available.</p>
}
else
{
    var filtered = latestReadings.Where(r => r.DeviceId.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || r.DeviceName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
    <input class="form-control mb-3" placeholder="Search by DeviceId or Name..." @bind="searchTerm" 
    @bind:event="oninput"/>
    
    
    
    @if (!filtered.Any())
    {
    <p class="text-muted">No sensors found.</p>
}

else
{
    <h4>Latest per sensor</h4>
    <table class="table">
        <thead>
            <tr>
                <th>DeviceId</th>
                <th>Name</th>
                <th>Type</th>
                <th>Value</th>
                <th>Timestamp</th>
                <th>ReceivedAt</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in filtered)
            {
                <tr>
                    <td>@r.DeviceId</td>
                    <td>@r.DeviceName</td>
                    <td>@r.SensorType</td>
                    <td>@r.LatestValue</td>
                    <td>@r.Timestamp</td>
                    <td>@r.ReceivedAt</td>
                </tr>
            }
        </tbody>
    </table>
}


    <h4>History</h4>
    <div class="mb-3">
        <select class="form-select" value="@selectedDeviceId" @onchange="OnSensorChanged">
            @foreach (var sensor in sensors)
            {
                <option value="@sensor.DeviceId">@sensor.DeviceId - @sensor.DeviceName (@sensor.SensorType)</option>
            }
        </select>
    </div>

    @if (historyReadings.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>DeviceId</th>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Timestamp</th>
                    <th>ReceivedAt</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in historyReadings)
                {
                    <tr>
                        <td>@r.DeviceId</td>
                        <td>@r.SensorType</td>
                        <td>@r.Value</td>
                        <td>@r.Timestamp</td>
                        <td>@r.ReceivedAt</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<SensorLatestDto> latestReadings = new();
    private List<SensorDto> sensors = new();
    private List<SensorHistoryDto> historyReadings = new();
    private bool isLoading = false;
    private string? selectedDeviceId;
    private string errorMessage = string.Empty;
    private string token = string.Empty;
    private string searchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Skydda sidan genom att kräva token innan data hämtas.
        token = await TokenStore.GetTokenAsync() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            // Hämta översikt + sensorlista först, därefter historik för vald sensor.
            latestReadings = await GetAuthorizedAsync<List<SensorLatestDto>>("api/measurements/latest") ?? new();
            sensors = await GetAuthorizedAsync<List<SensorDto>>("api/measurements/sensors") ?? new();

            if (!sensors.Any())
            {
                historyReadings = new();
                return;
            }

            selectedDeviceId ??= sensors[0].DeviceId;
            await LoadHistory();
        }
        catch
        {
            errorMessage = "Could not load dashboard data.";
            latestReadings = new();
            historyReadings = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSensorChanged(ChangeEventArgs args)
    {
        selectedDeviceId = args.Value?.ToString();
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        if (string.IsNullOrWhiteSpace(selectedDeviceId))
        {
            historyReadings = new();
            return;
        }

        historyReadings = await GetAuthorizedAsync<List<SensorHistoryDto>>($"api/measurements/history/{selectedDeviceId}?take=100") ?? new();
    }

    private async Task<T?> GetAuthorizedAsync<T>(string uri)
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, uri);
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        using var response = await Http.SendAsync(request);
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Om token är ogiltig: rensa lokal token och skicka användaren till login.
            await TokenStore.ClearTokenAsync();
            Nav.NavigateTo("/login");
            return default;
        }

        response.EnsureSuccessStatusCode();
        return await response.Content.ReadFromJsonAsync<T>();
    }

    public class SensorLatestDto
    {
        public string DeviceId { get; set; } = string.Empty;
        public string DeviceName { get; set; } = string.Empty;
        public string SensorType { get; set; } = string.Empty;
        public double LatestValue { get; set; }
        public DateTime Timestamp { get; set; }
        public DateTime ReceivedAt { get; set; }
    }

    public class SensorDto
    {
        public string DeviceId { get; set; } = string.Empty;
        public string DeviceName { get; set; } = string.Empty;
        public string SensorType { get; set; } = string.Empty;
    }

    public class SensorHistoryDto
    {
        public string DeviceId { get; set; } = string.Empty;
        public string SensorType { get; set; } = string.Empty;
        public double Value { get; set; }
        public DateTime Timestamp { get; set; }
        public DateTime ReceivedAt { get; set; }
    }
}