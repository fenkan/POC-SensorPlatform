@inherits LayoutComponentBase
@inject AuthTokenStore TokenStore
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page theme @ThemeCSSClass">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleTheme">
                Toggle Theme
            </button>

            @if (string.IsNullOrEmpty(token))
            {
                <button class="btn btn-primary btn-sm" @onclick='() => Nav.NavigateTo("/login")'>
                    Login
                </button>
            }
            else
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="Logout">
                    Logout
                </button>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _darkModeEnabled = false;
    private string token = string.Empty;

    private string ThemeCSSClass => _darkModeEnabled ? "dark-theme" : "";

    protected override async Task OnInitializedAsync()
    {
        token = await TokenStore.GetTokenAsync() ?? string.Empty;
        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
        _darkModeEnabled = saved == "true";
    }

    private async Task ToggleTheme()
    {
        _darkModeEnabled = !_darkModeEnabled;
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", _darkModeEnabled.ToString().ToLower());
    }

    private async Task Logout()
    {
        await TokenStore.ClearTokenAsync();
        token = string.Empty;
        Nav.NavigateTo("/login");
    }
}
